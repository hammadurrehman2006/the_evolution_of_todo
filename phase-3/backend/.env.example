# Database Configuration
# Neon PostgreSQL (Serverless)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# JWT Configuration
# Generate secure secret with: openssl rand -hex 32
JWT_SECRET=your-secret-key-here-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS Configuration (comma-separated origins)
# Add your frontend URLs (local and production)
CORS_ORIGINS=["http://localhost:3000", "https://your-frontend.vercel.app"]

# OpenRouter Configuration (for AI chatbot features)
# Use 'openrouter/free' for automatic free model selection
# See available free models: https://openrouter.ai/openrouter/free
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/free
