{
  "mcpServers": {
    "todo-mcp": {
      "command": "uv",
      "args": [
        "--directory",
        "${workspaceFolder}/phase-3/backend/mcp-server",
        "run",
        "python3",
        "src/server.py"
      ],
      "env": {
        "PYTHONPATH": ".",
        "DATABASE_URL": "${env:DATABASE_URL}",
        "MCP_USER_ID": "${env:MCP_USER_ID:-default-mcp-user}"
      }
    }
  }
}
